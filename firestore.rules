rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global catch-all default deny rules
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Collection matching and rules enforcement

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(userId);
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(customerId);
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(invoiceId);
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(transactionId);
    }

    match /system/{systemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(systemId);
    }
  }
}
